# Copy this file to .env.local and fill in your values.

# Pre-populates the API Base URL field in the UI.
NEXT_PUBLIC_API_BASE_URL=https://api.example.com

# Controls which token generator is used (mirrors setup.global.ts):
#   staging | production  → real OneLogin PKCE flow via AWS SSM + Secrets Manager
#   anything else (or unset) → stub generator using /development/flex-secret/auth/e2e/private_jwk
STAGE=development

# AWS region for Secrets Manager / SSM (uses default credential chain if unset)
# AWS_REGION=eu-west-2
