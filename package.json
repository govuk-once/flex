{
  "name": "flex",
  "type": "module",
  "scripts": {
    "dev": "flex",
    "deploy": "pnpm openapi:generate && pnpm --filter @platform/flex run deploy",
    "checkov": "nx affected --target=checkov",
    "tsc": "nx affected --target=tsc",
    "lint": "nx affected --target=lint",
    "lint:report": "eslint domains libs platform tests/e2e --format json --output-file eslint-report.json",
    "test": "nx affected --target=test --run",
    "test:coverage": "nx run-many --target=test:coverage --run",
    "test:e2e": "nx run-many --target=test:e2e --run",
    "jwt": "tsx scripts/generateToken.ts",
    "dastSetup": "tsx scripts/dastSetup.ts",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "cold-start:reset": "tsx scripts/coldStartReset.ts",
    "cold-start:run": "tsx scripts/coldStartRun.ts",
    "cold-start:sweep": "tsx scripts/coldStartSweep.ts",
    "cold-start:metrics": "tsx scripts/coldStartMetrics.ts",
    "docs:serve": "pnpm openapi:generate && serve docs"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudformation": "3.1032.0",
    "@aws-sdk/client-cloudwatch-logs": "3.1045.0",
    "@aws-sdk/client-lambda": "3.1045.0",
    "@flex/cli": "workspace:*",
    "@flex/config": "workspace:*",
    "@flex/utils": "workspace:*",
    "esbuild": "0.28.0",
    "eslint": "10.4.1",
    "nx": "22.7.5",
    "serve": "14.2.6",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "zod": "4.4.3",
    "zod-openapi": "5.4.6"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
