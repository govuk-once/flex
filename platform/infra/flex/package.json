{
  "name": "@platform/flex",
  "type": "module",
  "scripts": {
    "dev": "cdk watch",
    "hotswap": "cdk deploy --hotswap",
    "diff": "cdk diff",
    "deploy": "cdk deploy --all",
    "destroy": "cdk destroy --all",
    "synth": "cdk synth",
    "tsc": "tsc --noEmit",
    "lint": "eslint --max-warnings=0 .",
    "checkov": "cdk synth --quiet && checkov --config-file checkov.yaml -d cdk.out --framework cloudformation --compact --quiet"
  },
  "dependencies": {
    "@aws-sdk/client-ssm": "3.1053.0",
    "@flex/sdk": "workspace:*",
    "aws-cdk": "2.1124.1",
    "aws-cdk-lib": "2.257.0",
    "constructs": "10.6.0",
    "graphology": "0.26.0",
    "graphology-dag": "0.4.1",
    "jiti": "2.7.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@flex/config": "workspace:*",
    "@flex/utils": "workspace:*",
    "@types/node": "25.9.1",
    "eslint": "10.4.0",
    "tsx": "4.22.3",
    "typescript": "6.0.3"
  }
}
