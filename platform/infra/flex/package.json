{
  "name": "@platform/flex",
  "type": "module",
  "scripts": {
    "dev": "cdk watch",
    "hotswap": "cdk deploy --hotswap",
    "diff": "cdk diff",
    "deploy": "cdk deploy --all --concurrency 4 --require-approval never",
    "destroy": "cdk destroy --all",
    "synth": "cdk synth",
    "validate:integrations": "tsx src/scripts/validate-integrations.ts",
    "tsc": "tsc --noEmit",
    "lint": "eslint --max-warnings=0 .",
    "test": "vitest --passWithNoTests",
    "checkov": "cdk synth --quiet && checkov --config-file checkov.yaml -d cdk.out --framework cloudformation --compact --quiet"
  },
  "dependencies": {
    "@aws-sdk/client-ssm": "3.1084.0",
    "@flex/sdk": "workspace:*",
    "@flex/service-gateway": "workspace:*",
    "aws-cdk": "2.1130.0",
    "aws-cdk-lib": "2.261.0",
    "constructs": "10.6.0",
    "graphology": "0.26.0",
    "graphology-dag": "0.4.1",
    "jiti": "2.7.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@flex/config": "workspace:*",
    "@flex/utils": "workspace:*",
    "@types/node": "26.1.1",
    "eslint": "10.6.0",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
