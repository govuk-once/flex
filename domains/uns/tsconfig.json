{
  "extends": "@flex/config/tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@domain": ["./domain.config.ts"],
      "@schemas/*": ["./src/schemas/*"],
      "@services/*": ["./src/services/*"],
      "@tests/fixtures": ["./src/tests/fixtures.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "e2e/**/*.ts",
    "vitest.config.ts",
    "vitest.e2e.config.ts",
    "domain.config.ts"
  ]
}
