{
  "extends": "@flex/config/tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@domain": ["./domain.config.ts"],
      "@data/*": ["./src/data/*"],
      "@services/*": ["./src/services/*"],
      "@schemas/*": ["./src/schemas/*"],
      "@tests/fixtures": ["./src/tests/fixtures.ts"],
      "@utils/*": ["./src/utils/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "e2e/**/*.ts",
    "vitest.config.ts",
    "vitest.e2e.config.ts",
    "domain.config.ts"
  ]
}
