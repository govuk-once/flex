{
  "common": {
    "access": "private",
    "timeout": 30
  },
  "resources": {
    "flexPrivateGatewayUrl": "ssm:/flex/apigw/private/gateway-url:stage",
    "encryptionKeyArn": "kms:/flex-secret/encryption-key"
  },
  "integrations": {
    "dvlaAuthenticate": "gtw:dvla:GET /v1/authenticate",
    "dvlaRetrieveLicence": "gtw:dvla:GET /v1/licence/*",
    "dvlaTestNotification": "gtw:dvla:POST /v1/test-notification/*",
    "dvlaCustomerSummary": "gtw:dvla:GET /v1/customer-summary/*",
    "dvlaDriverSummary": "gtw:dvla:GET /v1/driver-summary/*",
    "udpGetLinkingId": "dom:udp:GET /v1/identity/*"
  },
  "routeConfig": {
    "get-users-drivers-licence": {
      "resources": ["flexPrivateGatewayUrl", "encryptionKeyArn"],
      "integrations": ["dvlaAuthenticate", "dvlaRetrieveLicence", "dvlaCustomerSummary", "udpGetLinkingId"]
    },
    "post-test-notification": {
      "resources": ["flexPrivateGatewayUrl", "encryptionKeyArn"],
      "integrations": ["dvlaAuthenticate", "dvlaTestNotification", "udpGetLinkingId"]
    },
    "get-customer-summary": {
      "resources": ["flexPrivateGatewayUrl", "encryptionKeyArn"],
      "integrations": ["dvlaAuthenticate", "dvlaCustomerSummary", "udpGetLinkingId"]
    },
    "get-driver-summary": {
      "resources": ["flexPrivateGatewayUrl", "encryptionKeyArn"],
      "integrations": ["dvlaAuthenticate", "dvlaDriverSummary", "udpGetLinkingId"]
    }
  }
}
