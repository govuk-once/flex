{
  "openapi": "3.1.0",
  "info": {
    "title": "DVLA Domain API",
    "version": "1.0.0",
    "description": "Driving licence, customer summary, and driver summary endpoints"
  },
  "paths": {
    "/v1/driving-licence": { "$ref": "routes/driving-licence.json" },
    "/v1/test-notification": { "$ref": "routes/test-notification.json" },
