    "/v1/driver-summary": { "$ref": "routes/driver-summary.json" }
  },
  "components": {
    "schemas": {
      "Address": { "$ref": "schemas/address.json" },
      "Driver": { "$ref": "schemas/driver.json" },
      "Licence": { "$ref": "schemas/licence.json" },
      "EntitlementRecord": { "$ref": "schemas/entitlement.json" },
      "Endorsement": { "$ref": "schemas/endorsement.json" },
      "ViewDriverResponse": { "$ref": "schemas/view-driver-response.json" },
      "AuthenticateResponse": { "$ref": "schemas/authenticate-response.json" }
    }
  }
