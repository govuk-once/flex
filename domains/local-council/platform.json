{
  "common": {
    "access": "isolated",
    "timeout": 30
  },
  "resources": {
    "flexPrivateGatewayUrl": "ssm:/flex/apigw/private/gateway-url:stage"
  },
  "integrations": {
    "udpSaveLocalAuthority": "gtw:udp:POST /v1/local-council/*",
    "udpGetLocalAuthority": "gtw:udp:GET /v1/local-council/*"
  },
  "routeConfig": {
    "get-local-authority": {
      "resources": ["flexPrivateGatewayUrl"],
      "integrations": ["udpGetLocalAuthority"]
    },
    "upsert-local-authority": {
      "resources": ["flexPrivateGatewayUrl"],
      "integrations": ["udpSaveLocalAuthority"]
    }
  }
}
