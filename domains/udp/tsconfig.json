{
  "extends": "@flex/config/tsconfig.json",
  "include": ["src/**/*.ts", "vitest.config.ts", "domain.config.ts"],
  "compilerOptions": {
    "paths": {
      "@domain": ["./domain.config.ts"],
      "@schemas": ["./src/schemas/index.ts"],
      "@schemas/*": ["./src/schemas/*"],
      "@utils": ["./src/utils/index.ts"],
      "@utils/*": ["./src/utils/*"],
      "@tests/fixtures": ["./src/tests/fixtures.ts"]
    }
  }
}
