{
  "extends": "@flex/config/tsconfig.json",
  "include": [
    "src/**/*.ts",
    "vitest.config.ts",
    "domain.config.ts",
    "domain.private.config.ts"
  ],
  "compilerOptions": {
    "paths": {
      "@schemas/*": ["./src/schemas/*"],
      "@services/*": ["./src/services/*"],
      "@client": ["./src/client"],
      "@types": ["./src/types/index.ts"],
      "@test/fixtures": ["./src/test/fixtures.ts"]
    }
  }
}
