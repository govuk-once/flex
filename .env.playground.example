# Copy this file to .env. Do not commit your filled-in .env file.

# Credentials for the One Login test account YOU create yourself
# (see "Creating your test account" in docs/playground-access.md).
# FLEX never sees these.
PLAYGROUND_EMAIL=
PLAYGROUND_PASSWORD=
PLAYGROUND_TOTP_SEED=

# OAuth client used to exchange your One Login login for a JWT.
# Shared with you by your FLEX contact.
PLAYGROUND_CLIENT_ID=
PLAYGROUND_AUTH_URL=
PLAYGROUND_TOKEN_URL=
PLAYGROUND_ONE_LOGIN_ENV=

# FLEX staging API base URL. Used when calling endpoints with your token,
# e.g. curl -H "Authorization: Bearer $TOKEN" $PLAYGROUND_API_URL/user
PLAYGROUND_API_URL=
