{
  "name": "@flex/utils",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "tsc": "tsc --noEmit",
    "lint": "eslint --max-warnings=0 .",
    "test": "vitest --passWithNoTests",
    "generate-oas": "tsx src/openapi/generate-docs.ts",
    "scalar": "pnpm generate-oas && http-server src/openapi -p 4200 -o/scalar.html -c-1",
    "swagger": "pnpm generate-oas && http-server src/openapi -p 4200 -o/swagger.html -c-1"
  },
  "dependencies": {
    "@flex/logging": "workspace:*",
    "http-errors": "2.0.1",
    "zod": "4.3.6",
    "zod-openapi": "5.4.6"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudformation": "3.1032.0",
    "@flex/config": "workspace:*",
    "@types/aws-lambda": "8.10.161",
    "@types/http-errors": "2.0.5",
    "@types/node": "25.6.0",
    "eslint": "10.2.1",
    "http-server": "14.1.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "undici-types": "8.1.0",
    "vitest": "4.1.4"
  }
}
