{
  "extends": "@flex/config/tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@client/*": ["./src/client/*"],
      "@config/*": ["./src/config/*"],
      "@handler/*": ["./src/handler/*"],
      "@tests/fixtures": ["./src/tests/fixtures.ts"],
      "@types": ["./src/types/index.ts"],
      "@types/*": ["./src/types/*"],
      "@utils/*": ["./src/utils/*"]
    }
  },
  "include": ["src/**/*.ts", "vitest.config.ts"]
}
